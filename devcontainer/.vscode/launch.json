      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Python: Hacking Menu",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/hacking-menu.py",
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}