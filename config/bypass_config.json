{
  "rate_limiting": {
    "enabled": true,
    "adaptive": true,
    "bypass_techniques": ["timing_randomization", "request_distribution", "session_cycling"]
  },
  "bypass_strategies": {
    "user_agent_rotation": {
      "enabled": true,
      "mobile_preference": true,
      "instagram_specific": true,
      "rotation_interval": 10
    },
    "proxy_cycling": {
      "enabled": true,
      "cycle_interval": 5,
      "health_check": true,
      "failure_tolerance": 3
    },
    "session_distribution": {
      "enabled": true,
      "load_balancing": true,
      "session_isolation": true,
      "failover": true
    },
    "timing_obfuscation": {
      "enabled": true,
      "random_delays": true,
      "human_behavior": true,
      "burst_prevention": true
    }
  },
  "instagram_api": {
    "endpoints": {
      "inbox": "https://i.instagram.com/api/v1/direct_v2/inbox/",
      "thread_items": "https://i.instagram.com/api/v1/direct_v2/threads/{thread_id}/items/",
      "thread_info": "https://i.instagram.com/api/v1/direct_v2/threads/{thread_id}/",
      "user_search": "https://i.instagram.com/api/v1/users/search/",
      "user_info": "https://i.instagram.com/api/v1/users/{user_id}/info/"
    },
    "headers": {
      "accept": "*/*",
      "accept-encoding": "gzip, deflate, br",
      "accept-language": "en-US,en;q=0.9",
      "cache-control": "no-cache",
      "pragma": "no-cache",
      "sec-fetch-dest": "empty",
      "sec-fetch-mode": "cors",
      "sec-fetch-site": "same-origin"
    }
  },
  "rate_limits": {
    "requests_per_minute": 15,
    "requests_per_hour": 200,
    "requests_per_day": 2000,
    "dm_requests_per_hour": 50,
    "profile_requests_per_hour": 100
  },
  "bypass_parameters": {
    "delay_min": 1.5,
    "delay_max": 4.0,
    "batch_size": 3,
    "concurrent_sessions": 5,
    "retry_attempts": 5,
    "exponential_backoff": true,
    "circuit_breaker": true
  },
  "stealth_features": {
    "fingerprint_spoofing": true,
    "behavior_randomization": true,
    "traffic_obfuscation": true,
    "anti_detection": true,
    "trace_removal": true
  }
}
