{
  "project": {
    "name": "SugarGlitch RealOps", 
    "version": "1.0.0",
    "description": "Advanced Real-time Operations & Intelligence Platform",
    "author": "SugarGlitch Team",
    "python_version": "3.12+",
    "node_version": "18+",
    "created": "2025-05-27",
    "last_updated": "2025-05-27T03:30:00.000000"
  },
  "database": {
    "path": "databases/stealth_intelligence.db",
    "backup_interval": 3600,
    "auto_backup": true,
    "max_connections": 10
  },
  "extractors": {
    "instagram": {
      "enabled": true,
      "rate_limit": 100,
      "delay_min": 1,
      "delay_max": 3,
      "max_retries": 3
    },
    "telegram": {
      "enabled": true,
      "sessions_path": "data/sessions/",
      "auto_save": true,
      "max_sessions": 50
    },
    "puppeteer": {
      "enabled": true,
      "headless": true,
      "timeout": 30000
    }
  },
  "proxy": {
    "enabled": true,
    "rotation_interval": 300,
    "providers": ["brightdata", "residential"],
    "max_retries": 5
  },
  "monitoring": {
    "extensions": {
      "enabled": true,
      "max_hosts": 2,
      "memory_threshold": 85,
      "check_interval": 30
    },
    "system": {
      "enabled": true,
      "alerts": true,
      "log_performance": true
    }
  },
  "web": {
    "enabled": false,
    "port": 8080,
    "host": "localhost",
    "cors": true
  },
  "settings": {
    "debug": false,
    "log_level": "INFO",
    "max_workers": 4,
    "timeout": 30,
    "retry_attempts": 3
  },
  "paths": {
    "data_dir": "data",
    "logs_dir": "logs",
    "config_dir": "config",
    "temp_dir": "temp",
    "backups_dir": "backups"
  },
  "security": {
    "encryption_enabled": true,
    "session_timeout": 3600,
    "max_login_attempts": 3,
    "secure_sessions": true
  }
}