# SugarGlitch RealOps Environment Variables
# Copy this file to .env and fill in your actual values

# === DOCKER COMPOSE CONFIGURATION ===
# PostgreSQL Database for Docker Compose
POSTGRES_USER=sguser
POSTGRES_PASSWORD=sgpass
POSTGRES_DB=sgdb
DATABASE_URL=postgresql://sguser:sgpass@db:5432/sgdb

# Application Configuration
PYTHONUNBUFFERED=1
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
COMPOSE_PROJECT_NAME=sugarglitch-realops

# === LEGACY/ALTERNATIVE DATABASE CONFIGURATION ===
# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sugarglitch_db
DB_USER=your_username
DB_PASSWORD=your_password

# Instagram API Configuration
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password
INSTAGRAM_SESSION_FILE=./config/sessions/instagram_session.json

# Target Configuration for Testing
TARGET_HOST=192.168.1.100
TARGET_PORT=22
TARGET_USERNAME=root
SSH_WORDLIST_PATH=./basic_wordlist.txt

# Penetration Testing Configuration
NMAP_TARGET_RANGE=192.168.1.0/24
BURP_PROXY=127.0.0.1:8080
METASPLOIT_HOST=127.0.0.1
METASPLOIT_PORT=55553

# Telegram Configuration
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=your_phone_number
TELEGRAM_SESSION=./config/sessions/telegram_session

# Proxy Configuration
PROXY_HOST=your_proxy_host
PROXY_PORT=your_proxy_port
PROXY_USERNAME=your_proxy_username
PROXY_PASSWORD=your_proxy_password
USE_PROXY=false
BRIGHT_DATA_USERNAME=your_brightdata_username
BRIGHT_DATA_PASSWORD=your_brightdata_password

# Security
SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# Discord Webhook (Optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# Notification Configuration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
NOTIFICATION_ENABLED=true

# Application Settings
DEBUG=false
LOG_LEVEL=INFO
MAX_WORKERS=4
RATE_LIMIT=60

# File Upload Settings
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE=50MB

# Monitoring
HEALTH_CHECK_INTERVAL=300
MEMORY_THRESHOLD=80
CPU_THRESHOLD=80

# Redis Configuration
REDIS_HOST=redis
