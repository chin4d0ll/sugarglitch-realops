{
  "name": "sugarglitch-realops",
  "version": "1.0.0",
  "description": "Advanced Real-time Operations & Intelligence Platform",
  "main": "main.js",
  "scripts": {
    "start": "node main.js",
    "dev": "nodemon main.js",
    "test": "jest",
    "build": "webpack --mode production",
    "clean": "rm -rf node_modules package-lock.json",
    "install-deps": "npm install && pip install -r requirements.txt",
    "setup": "npm run install-deps && python3 databases/enterprise_db_setup.py",
    "monitor": "python3 monitor_extensions.py",
    "fix-extensions": "./fix_extensions_rerun.sh"
  },
  "keywords": [
    "social-media",
    "instagram",
    "telegram",
    "data-extraction",
    "intelligence",
    "automation",
    "real-time",
    "monitoring"
  ],
  "author": "SugarGlitch Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "playwright": "^1.40.0",
    "puppeteer": "^24.9.0",
    "puppeteer-core": "^24.9.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "prettier": "^3.1.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/sugarglitch-realops.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/sugarglitch-realops/issues"
  },
  "homepage": "https://github.com/your-org/sugarglitch-realops#readme"
}
